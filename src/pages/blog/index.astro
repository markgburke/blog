---
import { getCollection } from 'astro:content';
import PaperPage from '../../layouts/PaperPage.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';

const all = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const total = all.length;

function readTime(body: string | undefined): number {
	const words = (body ?? '').trim().split(/\s+/).filter(Boolean).length;
	return Math.max(1, Math.round(words / 220));
}

const posts = all.map((post, i) => ({
	post,
	number: String(total - i).padStart(3, '0'),
	minutes: readTime(post.body),
}));

const countLabel = `— ${String(total).padStart(2, '0')} ${total === 1 ? 'ENTRY' : 'ENTRIES'} —`;
---

<PaperPage title={`Blog · ${SITE_TITLE}`} description={SITE_DESCRIPTION} activeNav="blog">
	<h3 class="section-heading">
		<span>Recent Entries</span>
		<span class="count">{countLabel}</span>
	</h3>

	<section class="posts">
		{
			posts.map(({ post, number, minutes }) => (
				<article class="post">
					<div class="post-date">
						<FormattedDate date={post.data.pubDate} />
						<span class="no">№ {number}</span>
					</div>
					<div class="post-body">
						<h2>
							<a href={`/blog/${post.id}/`}>{post.data.title}</a>
						</h2>
						<p class="post-excerpt">{post.data.description}</p>
						{post.data.tags && post.data.tags.length > 0 && (
							<div class="post-tags">
								{post.data.tags.map((t: string) => <span>{t}</span>)}
							</div>
						)}
					</div>
					<div class="post-meta">
						{minutes} min
						<br />
						<a class="read-link" href={`/blog/${post.id}/`}>
							read &rarr;
						</a>
					</div>
				</article>
			))
		}
	</section>
</PaperPage>
