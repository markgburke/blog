---
import { getCollection } from 'astro:content';
import BlogLayout     from '../../layouts/BlogLayout.astro';
import TopBar         from '../../components/blog/TopBar.astro';
import Hero           from '../../components/blog/Hero.astro';
import Ticker         from '../../components/blog/Ticker.astro';
import Nav            from '../../components/blog/Nav.astro';
import FeaturedPost   from '../../components/blog/FeaturedPost.astro';
import PostCard       from '../../components/blog/PostCard.astro';
import SidePanels     from '../../components/blog/SidePanels.astro';
import Footer         from '../../components/blog/Footer.astro';

const all = await getCollection('blog');
const posts = all
  .filter((p: any) => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const [featured, ...rest] = posts;
const totalCount = posts.length;

const readMinutes = (entry: any) => {
  const words = (entry.body || '').split(/\s+/).filter(Boolean).length;
  return Math.max(2, Math.round(words / 220));
};

const tickerItems = [
  `<b>NEW</b> ${featured?.data.title ?? 'New entry'} — entry <i>№${String(totalCount).padStart(3,'0')}</i>`,
  'now playing · <i>analog drift / lo-fi ambient</i>',
  `<b>UPDATE</b> archive re-indexed · ${totalCount} entries`,
  'uplink · <b>stable</b> · packet loss 0.0%',
  '<b>QUEUE</b> drafts pending · 03',
];
---
<BlogLayout title="NET/FEED — Mark Burke" description="Field notes & marginalia.">
  <div class="app">
    <TopBar />
    <Hero entryCount={totalCount} />
    <Ticker items={tickerItems} />
    <Nav current="feed" />

    <div class="grid">
      <section class="panel">
        <div class="panel-head">
          <div class="title">Feed · Recent Transmissions</div>
          <div class="meta">{posts.length} shown · sort: chronological ↓</div>
        </div>

        {featured && (
          <FeaturedPost
            href={`/blog/${featured.id}/`}
            number={totalCount}
            title={featured.data.title}
            description={featured.data.description}
            pubDate={featured.data.pubDate}
            tags={featured.data.tags ?? []}
            readMinutes={readMinutes(featured)}
          />
        )}

        {rest.map((post, i) => (
          <PostCard
            href={`/blog/${post.id}/`}
            number={totalCount - 1 - i}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            tags={post.data.tags ?? []}
            readMinutes={readMinutes(post)}
          />
        ))}
      </section>

      <SidePanels />
    </div>

    <Footer />
  </div>
</BlogLayout>
