---
interface Props { current?: string; }
const { current = "home" } = Astro.props;
const items = [
  { key: "home", num: "01", href: "/" },
  { key: "feed", num: "02", href: "/blog" },
  { key: "about", num: "03", href: "/about" },
];
---
<nav class="nav">
  {items.map(it => (
    <a href={it.href} class={it.key === current ? "current" : ""}>
      <span class="num">{it.num}</span>{it.key.charAt(0).toUpperCase() + it.key.slice(1)}
    </a>
  ))}
  <div class="spacer"></div>
  <a href="/rss.xml" class="rss-link">
    <span class="num">04</span>RSS
  </a>
</nav>
