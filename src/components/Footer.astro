---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Mark Burke. All rights reserved.
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	@media (prefers-color-scheme: dark) {
		footer {
			background: #1a1d2e;
		}
	}
</style>
