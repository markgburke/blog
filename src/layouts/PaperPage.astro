---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_TAGLINE, SITE_DESCRIPTION } from '../consts';

interface Props {
	title: string;
	description?: string;
	activeNav?: 'home' | 'blog' | 'about';
}

const { title, description = SITE_DESCRIPTION, activeNav = 'home' } = Astro.props;

const postCount = (await getCollection('blog')).length;
const issue = String(postCount).padStart(2, '0');
const today = new Date();
const dateLabel = today.toLocaleDateString('en-US', {
	weekday: 'long',
	month: 'long',
	day: 'numeric',
	year: 'numeric',
});
const year = today.getFullYear();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<article class="page">
			<div class="margin-rule"></div>
			<div class="holes" aria-hidden="true">
				<span></span><span></span><span></span><span></span><span></span><span></span>
			</div>

			<header class="masthead">
				<h1 class="masthead-title">
					<a href="/">{SITE_TITLE}</a><span class="caret"></span>
				</h1>
				<div class="masthead-meta">
					<span class="label">Vol. I · Issue {issue}</span>
					{dateLabel}
				</div>

				<div class="masthead-sub">
					<span class="byline"><em>{SITE_TAGLINE}</em> — one page at a time.</span>
					<nav class="typed-nav" aria-label="Primary">
						<a href="/" class={activeNav === 'home' ? 'current' : undefined}>home</a>
						<a href="/blog" class={activeNav === 'blog' ? 'current' : undefined}>blog</a>
						<a href="/about" class={activeNav === 'about' ? 'current' : undefined}>about</a>
						<a href="/rss.xml">rss</a>
					</nav>
				</div>
			</header>

			<slot />

			<footer class="page-footer">
				<div>
					<div class="signoff">Yours, from the margins —</div>
					<div class="signature">Mark Burke</div>
				</div>
				<div class="rightcol">
					© {year} · Mark Burke<br />
					Typeset in Courier Prime.<br />
					<a href="/rss.xml">rss</a> · <a href="/about">about</a>
				</div>
			</footer>
		</article>
	</body>
</html>
