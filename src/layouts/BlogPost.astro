---
import { getCollection, type CollectionEntry } from 'astro:content';
import PaperPage from './PaperPage.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & { slug?: string };

const { title, description, pubDate, updatedDate, tags, slug } = Astro.props;

const all = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const total = all.length;
const idx = slug ? all.findIndex((p) => p.id === slug) : -1;
const number = idx >= 0 ? String(total - idx).padStart(3, '0') : null;
---

<PaperPage title={`${title} · ${SITE_TITLE}`} description={description} activeNav="blog">
	<article>
		<header class="article-head">
			<div class="kicker">
				{number && <span class="no">№ {number}</span>}
				<FormattedDate date={pubDate} />
				{tags && tags.length > 0 && tags.map((t) => <span>#{t}</span>)}
			</div>
			<h1>{title}</h1>
			{description && <p class="description">{description}</p>}
			{
				updatedDate && (
					<div class="last-updated-on">
						Last updated on <FormattedDate date={updatedDate} />
					</div>
				)
			}
		</header>
		<div class="prose">
			<slot />
		</div>
		<div class="article-back">
			<a href="/blog">&larr; Back to recent entries</a>
		</div>
	</article>
</PaperPage>
